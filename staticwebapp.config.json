{
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "routes": [
    { "route": "/styles.css", "headers": { "Cache-Control": "public, max-age=604800" } },
    { "route": "/app.js", "headers": { "Cache-Control": "public, max-age=604800" } },
    { "route": "/config.json", "headers": { "Cache-Control": "no-cache" } },
    { "route": "/content.json", "headers": { "Cache-Control": "no-cache" } }
  ],
  "mimeTypes": {
    ".json": "application/json; charset=utf-8"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["*.css", "*.js", "*.json", "*.jpg", "*.jpeg", "*.png", "*.webp", "*.mp4"]
  }
}
